        <TextView name="PvPAnnihilationMatchesLost_value" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3  )"/>
      </LayoutRow>
      <LayoutRow>
        <TextView name="PvPCTFMatchesWon_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3 )"/>
        <TextView name="PvPCTFMatchesWon_value_seasonal" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3 )"/>
        <TextView name="PvPCTFMatchesWon_value" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3 )"/>
      </LayoutRow>
      <LayoutRow>
        <TextView name="PvPCTFMatchesLost_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3 )"/>
        <TextView name="PvPCTFMatchesLost_value_seasonal" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3 )"/>
        <TextView name="PvPCTFMatchesLost_value" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3 )"/>
      </LayoutRow>
	  <LayoutRow>
        <TextView name="PvPConquestMatchesWon_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
        <TextView name="PvPConquestMatchesWon_value_seasonal" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3  )"/>
        <TextView name="PvPConquestMatchesWon_value" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3  )"/>
      </LayoutRow>
