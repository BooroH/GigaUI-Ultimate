        <TextView name="PvPTournamentMatchesWon_value" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3  )"/>
      </LayoutRow>
      <LayoutRow>
        <TextView name="PvPSiegeMatchesWon_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
        <TextView name="PvPSiegeMatchesWon_value_seasonal" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3  )"/>
