        <TextView name="PvPSiegeMatchesLost_value_seasonal" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3  )"/>
        <TextView name="PvPSiegeMatchesLost_value" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3  )"/>
