<View xmlns:template="template.dtd"
        view_layout="vertical"
        layout_inner_borders="Rect(0,7,0,14)"
        >
  <template:BitmapView template:name="HDivider"
          layout_col_span="3"
          bitmap_gfx="sidebars/horizontal_dividerline.tga"
          max_size_extend="Point(COORD_MAX,-1)"
          _min_size_extend="Point(300,-1)"
          layout_borders="Rect(0,6,0,6)"/>
  <template:BitmapView template:name="VDivider"
          bitmap_gfx="GUIcomponents/list_vertical_dividesr.tga"
          max_size_extend="Point(-1,COORD_MAX)"
          layout_borders="Rect(8,0,8,0)"/>
  <template:TextView feature_flags="TVF_ENABLE_SHADOW|TVF_RENDER_SHADOW|TVF_RENDER_HALO"/>

  <View view_layout="vertical" min_size_extend="Point(COORD_MAX,-1)" layout_inner_borders="Rect(0,10,0,15)" h_local_alignment="LEFT">

    <View view_layout="grid" _max_size_extend="Point(COORD_MAX,-1)" h_local_alignment="LEFT">

      <LayoutRow>
        <TextView value_token="Level"
            font="LARGE"
            default_color="ACTIVE"
            h_local_alignment="LEFT"
            layout_borders="Rect(0,0,10,3 )"/>
        <TextView value_token="Experience"
                    font="LARGE"
                    default_color="ACTIVE"
                    h_local_alignment="LEFT"
                    layout_borders="Rect(0,0,0,3 )"/>
      </LayoutRow>

      <LayoutRow>
        <TextView name="PvPLevel_value" default_color="positive" h_local_alignment="LEFT" layout_borders="Rect(0,0,10,3 )"/>
        <View view_layout="grid" _max_size_extend="Point(COORD_MAX,-1)">
          <TextView name="Experience_value" default_color="positive" h_local_alignment="LEFT" layout_borders="Rect(0,0,0,3 )"/>
          <TextView value=" / " h_local_alignment="LEFT" layout_borders="Rect(0,0,0,3 )"/>
          <TextView name="Next_Experience_value" default_color="positive" h_local_alignment="LEFT" layout_borders="Rect(0,0,0,3 )"/>
          <TextView value=" " h_local_alignment="LEFT" layout_borders="Rect(0,0,0,3 )"/>
          <TextView value="( " h_local_alignment="LEFT"  layout_borders="Rect(0,0,0,3 )"/>
          <TextView name="Experience_Percentage_value" default_color="positive" h_local_alignment="LEFT" layout_borders="Rect(0,0,0,3 )"/>
          <TextView value=" )" h_local_alignment="LEFT" layout_borders="Rect(0,0,0,3 )" />
        </View>
      </LayoutRow>
    </View>
    
    <View view_layout="grid" _max_size_extend="Point(COORD_MAX,-1)" h_local_alignment="LEFT">

      <LayoutRow>
        <BitmapView template:source="HDivider"/>
      </LayoutRow>

      <LayoutRow>
        <TextView value_token="PvPStats"
                    font="LARGE"
                    default_color="ACTIVE"
                    h_local_alignment="LEFT"
                    layout_borders="Rect(0,0,8,3 )"/>
        <TextView value_token="PvPStatsSeasonal"
                    font="LARGE"
                    default_color="ACTIVE"
                    h_local_alignment="LEFT"
                    layout_borders="Rect(0,0,8,3 )"/>
        <TextView value_token="PvPStatsOverall"
                    font="LARGE"
                    default_color="ACTIVE"
                    h_local_alignment="LEFT"
                    layout_borders="Rect(0,0,8,3 )"/>
      </LayoutRow>
      <LayoutRow>
        <TextView name="PvPKills_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3 )"/>
        <TextView name="PvPKills_value_seasonal" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3 )"/>
        <TextView name="PvPKills_value" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3 )"/>
      </LayoutRow>
      <LayoutRow>
