        <TextView name="PvPMachesAbandoned_value_seasonal" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3  )"/>
        <TextView name="PvPMachesAbandoned_value" h_local_alignment="LEFT"  layout_borders="Rect(0,0,8,3  )"/>
